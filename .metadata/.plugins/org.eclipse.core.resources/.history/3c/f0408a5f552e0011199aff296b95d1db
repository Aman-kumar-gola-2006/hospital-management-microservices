package com.hospital.auth.controller;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import com.hospital.auth.dto.AuthResponse;
import com.hospital.auth.service.AuthService;
import com.hospital.auth.utils.JwtUtil;

@RestController
@RequestMapping("/auth")
public class GoogleAuthController {

    @Autowired
    private AuthService authService;

    @Autowired
    private JwtUtil jwtUtil;

    // Step 1: Google login page redirect
    @GetMapping("/google-login")
    public String googleLogin() {
        return "redirect:/oauth2/authorization/google";
    }

    // Step 2: Google callback
    @GetMapping("/google-callback")
    public AuthResponse googleCallback(@RequestParam String code) {
        // Exchange code for user info (simplified - use OAuth2 client)
        // For demo, you need to get user info from Google using code
        // Here's a simplified version
        return authService.googleLoginWithCode(code);
    }
}