package com.hospital.auth.controller;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;
import com.hospital.auth.dto.AuthResponse;
import com.hospital.auth.service.AuthService;

@RestController
@RequestMapping("/auth")
public class GoogleAuthController {

    @Autowired
    private AuthService authService;

    @GetMapping("/google-success")
    public AuthResponse googleSuccess(@RequestParam(required = false) String code) {
        System.out.println("=== Google Callback Received ===");
        System.out.println("Code: " + code);
        
        // For now, return a response
        return new AuthResponse(null, "Google login callback received. Code: " + code);
    }
}